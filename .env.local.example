# Copy this file to .env.local and fill in your values
# NEVER commit .env.local to git

# Klaviyo — get these from your Klaviyo account
# Private API Key: Klaviyo Dashboard → Account → Settings → API Keys → Create Private API Key
# Scopes needed: Lists (Read/Write), Profiles (Read/Write), Subscriptions (Write)
KLAVIYO_PRIVATE_API_KEY=pk_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# List ID: Klaviyo → Lists & Segments → your waitlist list → the ID in the URL
# Example: https://www.klaviyo.com/list/ABC123/members → List ID is ABC123
KLAVIYO_LIST_ID=XXXXXX
